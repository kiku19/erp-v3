# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/appdb

# =============================================================================
# Seed Superadmin User (Optional - defaults used if not set)
# =============================================================================
# Superadmin credentials - use this to log in and create more users via admin panel
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=superadmin123
SEED_SUPERADMIN_ROLE=superadmin
SEED_SUPERADMIN_REDIRECT_PATH=/admin-panel

# =============================================================================
# JWT — must match the Kong consumer key (key_claim_name: iss in kong.yaml)
# In production, set this to your auth domain issuer value.
# =============================================================================
JWT_ISSUER=nextjs-app

# JWT token lifetimes (format: <number><m|h|d> for minutes/hours/days)
# Stricter values recommended for production (e.g. 15m user, 5m admin).
JWT_ACCESS_TOKEN_EXPIRY_USER=1h
JWT_ACCESS_TOKEN_EXPIRY_ADMIN=15m
JWT_REFRESH_TOKEN_EXPIRY_DAYS=7

# =============================================================================
# Test Environment
# =============================================================================

# Base URL for integration tests hitting the Next.js app directly.
BASE_URL=http://localhost:3002

# Base URL for Kong gateway tests. Set this when docker compose is running.
# When set, the Kong test suite will run automatically alongside the direct suite.
# Kong proxy listens on port 8000 by default.
KONG_BASE_URL=http://localhost:8000

# =============================================================================
# Frontend — Kong Gateway Base URL
# ALL browser/frontend API calls MUST go through Kong — per FRONTEND_STANDARDS.md
# This is a NEXT_PUBLIC_ variable and will be exposed to the browser bundle.
# =============================================================================
NEXT_PUBLIC_KONG_BASE_URL=http://localhost:8000

# =============================================================================
# Upstash Redis — required for rate limiting
# Get credentials at https://console.upstash.com
# =============================================================================
UPSTASH_REDIS_REST_URL=https://<your-upstash-endpoint>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# =============================================================================
# Rate Limiter Configuration
# =============================================================================

# Master toggle. Set to "false" to disable rate limiting entirely (e.g. local dev).
RATE_LIMIT_ENABLED=true

# Maximum number of requests allowed per window per IP.
RATE_LIMIT_MAX_REQUESTS=100

# Sliding window size in seconds.
RATE_LIMIT_WINDOW_SECONDS=60

# Comma-separated list of /api paths to exclude from rate limiting.
# Exact prefix match — e.g. "/api/health" excludes "/api/health" and "/api/health/live".
# Example: RATE_LIMIT_EXCLUDED_PATHS=/api/health,/api/webhooks
RATE_LIMIT_EXCLUDED_PATHS=

# =============================================================================
# Base URL Configuration (single source of truth)
# =============================================================================
APP_HOST=localhost
APP_PORT=3002
APP_BASE_URL=http://localhost:3002

# For Kong CORS configuration
CORS_ORIGIN=http://localhost:3002
