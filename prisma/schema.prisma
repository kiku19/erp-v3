generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                     String    @id @default(cuid())
  tenantName             String
  email                  String    @unique
  password               String
  role                   String    @default("admin")
  accessTokenExpiryMins  Int       @default(15)
  refreshTokenExpiryDays Int       @default(7)
  rememberMeExpiryDays   Int       @default(30)
  refreshToken           String?
  refreshTokenExpiresAt  DateTime?
  accessTokenExpiresAt   DateTime?
  emailVerified          Boolean   @default(false)
  companyName            String?
  companySize            String?
  industry               String?
  userRole               String?
  country                String?
  currency               String?
  onboardingCompleted    Boolean   @default(false)
  isDeleted              Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  users                    User[]
  canvasSnapshots          CanvasSnapshot[]
  emailVerificationTokens  EmailVerificationToken[]
  roles                    Role[]
  costCenters              CostCenter[]

  @@index([email, isDeleted])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  role      String   @default("member")
  password  String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  canvasEvents  CanvasEvent[]
  plannerEvents PlannerEvent[]

  @@unique([tenantId, email])
  @@index([tenantId, isDeleted])
}

model Eps {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  sortOrder Int      @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nodes    Node[]
  projects Project[]

  @@index([tenantId, isDeleted])
}

model Node {
  id           String   @id @default(cuid())
  tenantId     String
  epsId        String
  parentNodeId String?
  name         String
  sortOrder    Int      @default(0)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  eps        Eps       @relation(fields: [epsId], references: [id])
  parentNode Node?     @relation("NodeToNode", fields: [parentNodeId], references: [id])
  childNodes Node[]    @relation("NodeToNode")
  projects   Project[]

  @@index([tenantId, isDeleted])
  @@index([epsId, isDeleted])
  @@index([parentNodeId, isDeleted])
}

model Project {
  id                 String    @id @default(cuid())
  tenantId           String
  epsId              String
  nodeId             String?
  projectId          String
  name               String
  status             String    @default("Planning")
  responsibleManager String?
  startDate          DateTime?
  finishDate         DateTime?
  percentDone        Float     @default(0)
  budget             Float     @default(0)
  actualCost         Float     @default(0)
  eac                Float     @default(0)
  sortOrder            Int       @default(0)
  defaultCalendarId    String?
  isDeleted            Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  eps                   Eps                    @relation(fields: [epsId], references: [id])
  node                  Node?                  @relation(fields: [nodeId], references: [id])
  defaultCalendar       Calendar?              @relation("ProjectDefaultCalendar", fields: [defaultCalendarId], references: [id])
  plannerEvents         PlannerEvent[]
  wbsNodes              WbsNode[]
  activities            Activity[]
  activityRelationships ActivityRelationship[]
  resources             Resource[]
  resourceAssignments   ResourceAssignment[]
  calendars             Calendar[]             @relation("ProjectCalendars")

  @@unique([tenantId, projectId])
  @@index([tenantId, isDeleted])
  @@index([epsId, isDeleted])
  @@index([nodeId, isDeleted])
}

model CanvasEvent {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  version    Int
  eventType  String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId, version])
  @@index([tenantId, entityId])
}

model CanvasSnapshot {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model WbsNode {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String
  parentId  String?
  wbsCode   String
  name      String
  sortOrder Int      @default(0)
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project    Project    @relation(fields: [projectId], references: [id])
  parentWbs  WbsNode?   @relation("WbsToWbs", fields: [parentId], references: [id])
  childWbs   WbsNode[]  @relation("WbsToWbs")
  activities Activity[]

  @@unique([tenantId, projectId, wbsCode])
  @@index([tenantId, projectId, isDeleted])
  @@index([parentId, isDeleted])
}

model Activity {
  id              String    @id @default(cuid())
  tenantId        String
  projectId       String
  wbsNodeId       String
  activityId      String
  name            String
  activityType    String    @default("task")
  duration        Int       @default(0)
  durationUnit    String    @default("days")
  uom             String    @default("")
  totalQuantity   Float     @default(0)
  totalWorkHours  Float     @default(0)
  startDate       DateTime?
  finishDate      DateTime?
  percentComplete Float     @default(0)
  calendarId      String?
  sortOrder       Int       @default(0)
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project             Project                @relation(fields: [projectId], references: [id])
  wbsNode             WbsNode                @relation(fields: [wbsNodeId], references: [id])
  calendar            Calendar?              @relation(fields: [calendarId], references: [id])
  predecessorRels     ActivityRelationship[] @relation("SuccessorRels")
  successorRels       ActivityRelationship[] @relation("PredecessorRels")
  resourceAssignments ResourceAssignment[]

  @@unique([tenantId, projectId, activityId])
  @@index([tenantId, projectId, isDeleted])
  @@index([wbsNodeId, isDeleted])
}

model Calendar {
  id          String    @id @default(cuid())
  tenantId    String
  projectId   String?
  name        String
  category    String    @default("global")
  hoursPerDay Float     @default(8)
  workDays    Json
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project            Project?              @relation("ProjectCalendars", fields: [projectId], references: [id])
  defaultForProjects Project[]             @relation("ProjectDefaultCalendar")
  exceptions         CalendarException[]
  activities         Activity[]

  @@index([tenantId, isDeleted])
  @@index([tenantId, projectId, isDeleted])
}

model CalendarException {
  id            String    @id @default(cuid())
  tenantId      String
  calendarId    String
  name          String
  date          DateTime
  endDate       DateTime?
  exceptionType String    @default("Holiday")
  startTime     String?
  endTime       String?
  reason        String?
  workHours     Float?
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  calendar Calendar @relation(fields: [calendarId], references: [id])

  @@index([tenantId, calendarId, isDeleted])
}

model PlannerEvent {
  id         String   @id @default(cuid())
  tenantId   String
  projectId  String
  userId     String
  version    Int
  eventType  String
  entityType String
  entityId   String
  payload    Json
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([tenantId, projectId, version])
  @@index([tenantId, projectId, entityId])
}

model PlannerSnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String   @unique
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([tenantId, projectId])
}

model Resource {
  id             String   @id @default(cuid())
  tenantId       String
  projectId      String
  name           String
  resourceType   String   @default("labor")
  maxUnitsPerDay Float    @default(8)
  costPerUnit    Float    @default(0)
  sortOrder      Int      @default(0)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project     Project              @relation(fields: [projectId], references: [id])
  assignments ResourceAssignment[]

  @@index([tenantId, projectId, isDeleted])
}

model ResourceAssignment {
  id           String   @id @default(cuid())
  tenantId     String
  projectId    String
  activityId   String
  resourceId   String
  unitsPerDay  Float    @default(1)
  budgetedCost Float    @default(0)
  actualCost   Float    @default(0)
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project  Project  @relation(fields: [projectId], references: [id])
  activity Activity @relation(fields: [activityId], references: [id])
  resource Resource @relation(fields: [resourceId], references: [id])

  @@unique([tenantId, activityId, resourceId])
  @@index([tenantId, projectId, isDeleted])
  @@index([activityId, isDeleted])
  @@index([resourceId, isDeleted])
}

model ProjectLayout {
  id              String   @id @default(cuid())
  tenantId        String
  name            String
  description     String   @default("")
  structure       Json
  sourceProjectId String?
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, isDeleted])
}

model ActivityRelationship {
  id               String   @id @default(cuid())
  tenantId         String
  projectId        String
  predecessorId    String
  successorId      String
  relationshipType String   @default("FS")
  lag              Int      @default(0)
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  project     Project  @relation(fields: [projectId], references: [id])
  predecessor Activity @relation("PredecessorRels", fields: [predecessorId], references: [id])
  successor   Activity @relation("SuccessorRels", fields: [successorId], references: [id])

  @@unique([tenantId, predecessorId, successorId])
  @@index([tenantId, projectId, isDeleted])
  @@index([predecessorId, isDeleted])
  @@index([successorId, isDeleted])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  tenantId  String
  token     String    @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([token])
  @@index([tenantId, isDeleted])
}

model Role {
  id               String   @id @default(cuid())
  tenantId         String
  name             String
  code             String
  level            String   @default("Junior")
  defaultPayType   String   @default("hourly")
  overtimeEligible Boolean  @default(false)
  skillTags        String[] @default([])
  costRateMin      Float?
  costRateMax      Float?
  costRateCurrency String?
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isDeleted])
}

model CostCenter {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  description String   @default("")
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isDeleted])
}

model OBSNode {
  id               String   @id @default(cuid())
  tenantId         String
  parentId         String?
  name             String
  code             String
  type             String   @default("DIVISION")
  nodeHeadPersonId String?
  calendarId       String?
  costCenterId     String?
  assignedRoles    Json     @default("[]")
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parentNode OBSNode?      @relation("OBSNodeTree", fields: [parentId], references: [id])
  childNodes OBSNode[]     @relation("OBSNodeTree")
  people     OBSPerson[]
  equipment  OBSEquipment[]
  materials  OBSMaterial[]

  @@unique([tenantId, code])
  @@index([tenantId, isDeleted])
  @@index([tenantId, parentId, isDeleted])
}

model OBSPerson {
  id              String    @id @default(cuid())
  tenantId        String
  nodeId          String?
  name            String
  employeeId      String
  email           String
  roleId          String?
  payType         String    @default("hourly")
  standardRate    Float?
  overtimeRate    Float?
  overtimePay     Boolean   @default(false)
  monthlySalary   Float?
  dailyAllocation Float?
  contractAmount  Float?
  employmentType  String    @default("full-time")
  joinDate        DateTime?
  photoUrl        String?
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  node OBSNode? @relation(fields: [nodeId], references: [id])

  @@unique([tenantId, employeeId])
  @@index([tenantId, isDeleted])
  @@index([tenantId, nodeId, isDeleted])
}

model OBSEquipment {
  id               String    @id @default(cuid())
  tenantId         String
  nodeId           String
  name             String
  code             String
  category         String    @default("other")
  ownershipType    String    @default("owned")
  billingType      String    @default("owned-internal")
  standardRate     Float     @default(0)
  idleRate         Float?
  mobilizationCost Float?
  rentalStart      DateTime?
  rentalEnd        DateTime?
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  node OBSNode @relation(fields: [nodeId], references: [id])

  @@unique([tenantId, code])
  @@index([tenantId, isDeleted])
  @@index([tenantId, nodeId, isDeleted])
}

model OBSMaterial {
  id                  String   @id @default(cuid())
  tenantId            String
  nodeId              String
  name                String
  sku                 String
  category            String   @default("consumable")
  uom                 String   @default("piece")
  standardCostPerUnit Float    @default(0)
  costBasis           String   @default("fixed")
  wastageStandardPct  Float    @default(0)
  leadTimeDays        Int?
  reorderPointQty     Int?
  isDeleted           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  node OBSNode @relation(fields: [nodeId], references: [id])

  @@unique([tenantId, sku])
  @@index([tenantId, isDeleted])
  @@index([tenantId, nodeId, isDeleted])
}
