// Prisma schema for Auth/RBAC
// Database: PostgreSQL with Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Tenant model — minimal auth-layer record (auth infrastructure only)
// Business data (profiles, billing, settings) lives in MongoDB keyed by tenant_id
model Tenant {
  id        String   @id @default(uuid())
  name      String
  status    String   @default("active") // active | suspended
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("tenants")
}

// User model for authentication and RBAC
model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  role         String   @default("user") // user, admin, superadmin
  permissions  Json     @default("[]") // Array of permission strings
  timezone            String   @default("UTC")
  defaultRedirectPath String   @default("/dashboard") @map("default_redirect_path")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

// RefreshToken model for token refresh
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
