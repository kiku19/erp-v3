generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                      String    @id @default(cuid())
  tenantName              String
  email                   String    @unique
  password                String
  role                    String    @default("admin")
  accessTokenExpiryMins   Int       @default(15)
  refreshTokenExpiryDays  Int       @default(7)
  rememberMeExpiryDays    Int       @default(30)
  refreshToken            String?
  refreshTokenExpiresAt   DateTime?
  accessTokenExpiresAt    DateTime?
  isDeleted               Boolean   @default(false)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  users                   User[]
  canvasSnapshots         CanvasSnapshot[]

  @@index([email, isDeleted])
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  email     String
  name      String
  role      String   @default("member")
  password  String
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  canvasEvents  CanvasEvent[]
  plannerEvents PlannerEvent[]

  @@unique([tenantId, email])
  @@index([tenantId, isDeleted])
}

model Eps {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  sortOrder   Int       @default(0)
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  nodes       Node[]
  projects    Project[]

  @@index([tenantId, isDeleted])
}

model Node {
  id            String    @id @default(cuid())
  tenantId      String
  epsId         String
  parentNodeId  String?
  name          String
  sortOrder     Int       @default(0)
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  eps           Eps       @relation(fields: [epsId], references: [id])
  parentNode    Node?     @relation("NodeToNode", fields: [parentNodeId], references: [id])
  childNodes    Node[]    @relation("NodeToNode")
  projects      Project[]

  @@index([tenantId, isDeleted])
  @@index([epsId, isDeleted])
  @@index([parentNodeId, isDeleted])
}

model Project {
  id                 String    @id @default(cuid())
  tenantId           String
  epsId              String
  nodeId             String?
  projectId          String
  name               String
  status             String    @default("Planning")
  responsibleManager String?
  startDate          DateTime?
  finishDate         DateTime?
  percentDone        Float     @default(0)
  budget             Float     @default(0)
  actualCost         Float     @default(0)
  eac                Float     @default(0)
  sortOrder          Int       @default(0)
  isDeleted          Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  eps                Eps             @relation(fields: [epsId], references: [id])
  node               Node?           @relation(fields: [nodeId], references: [id])
  plannerEvents      PlannerEvent[]

  @@unique([tenantId, projectId])
  @@index([tenantId, isDeleted])
  @@index([epsId, isDeleted])
  @@index([nodeId, isDeleted])
}

model CanvasEvent {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  version    Int
  eventType  String
  entityType String
  entityId   String
  payload    Json
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([tenantId, version])
  @@index([tenantId, entityId])
}

model CanvasSnapshot {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model PlannerEvent {
  id         String   @id @default(cuid())
  tenantId   String
  projectId  String
  userId     String
  version    Int
  eventType  String
  entityType String
  entityId   String
  payload    Json
  isDeleted  Boolean  @default(false)
  createdAt  DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@index([tenantId, projectId, version])
  @@index([tenantId, projectId, entityId])
}

model PlannerSnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  projectId String   @unique
  version   Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([tenantId, projectId])
}
