#!/bin/sh
# pre-commit hook — runs all unit + component tests before every commit.
# Commit is blocked if any test fails.

echo ""
echo "🔍 Running unit & component tests (Jest)…"
echo ""

npm run test

EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌  Commit blocked: unit tests failed."
  echo "    Fix the failing tests and try again."
  echo ""
  exit 1
fi

echo ""
echo "✅  All unit tests passed. Proceeding with commit."
echo ""
